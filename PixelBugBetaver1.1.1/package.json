{
  "name": "pixel-bug",
  "version": "1.1.1",
  "description": "Pixel art and sprite editor",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "pixel-art",
    "sprite",
    "editor"
  ],
  "author": "KeyOuts",
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.0.12"
  },
  "productName": "Pixel Bug Beta",
  "build": {
    "appId": "com.pixelbug.beta",
    "productName": "Pixel Bug Beta",
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json",
      "README.md"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": "nsis"
    },
    "mac": {
      "icon": "assets/icon.png",
      "target": "dmg"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": "AppImage"
    },
    "nsis": {
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Pixel Bug Beta"
    }
  }
}
